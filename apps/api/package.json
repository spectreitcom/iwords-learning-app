    "class-validator": "^0.15.1",
    "date-fns": "^4.1.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "joi": "^18.1.2",
    "nest-commander": "^3.20.1",
    "openai": "^6.34.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "prisma": "^7.7.0",
    "reflect-metadata": "^0.2.2",
