// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Outbox
model OutboxMessage {
  id          String @id @default(cuid())
  eventName   String
  payload     Json
  aggregateId String

  // publishing fields
  status        OutboxStatus @default(PENDING)
  attempts      Int          @default(0)
  nextAttemptAt DateTime     @default(now())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([status, nextAttemptAt])
}

enum OutboxStatus {
  PENDING
  PUBLISHED
  FAILED
}

//----------------------------------

// Inbox
model InboxMessage {
  id      String      @id @default(cuid())
  payload Json
  status  InboxStatus @default(PENDING)
  topic   String
  source  String

  // Publishing fields
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  attempts      Int      @default(0)
  nextAttemptAt DateTime @default(now())

  @@index([status])
}

enum InboxStatus {
  PENDING
  PUBLISHED
  FAILED
}

//----------------------------------

// Users Bounded Context
model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique
  email     String   @unique
  name      String
  blocked   Boolean  @default(false)
  createdAt DateTime @default(now())
}

//----------------------------------

// Admin Identity Bounded Context
model AdminUser {
  id                 String   @id @default(uuid())
  email              String   @unique
  password           String?
  name               String
  isSuperuser        Boolean  @default(false)
  blocked            Boolean  @default(false)
  createdAt          DateTime @default(now())
  resetPasswordToken String?
}

//----------------------------------

// Dictionary Bounded Context
model Expression {
  id                 String              @id @default(uuid())
  phrase             String              @unique
  createdAt          DateTime            @default(now())
  expressionContexts ExpressionContext[]
}

model ExpressionContext {
  id          String   @id @default(uuid())
  translation String
  isCountable Boolean  @default(false)
  type        String
  forms       String[] @default([])
  isIrregular Boolean  @default(false)
  createdAt   DateTime @default(now())

  expressionId String
  expression   Expression @relation(fields: [expressionId], references: [id], onDelete: Cascade)
  sentences    Sentence[]
}

model Sentence {
  id          String   @id @default(uuid())
  translation String
  content     String
  createdAt   DateTime @default(now())

  expressionContextId String
  expressionContext   ExpressionContext @relation(fields: [expressionContextId], references: [id], onDelete: Cascade)
}

model DictionaryReadModel {
  id                  String   @id @default(uuid())
  phrase              String
  expressionId        String
  expressionContextId String   @unique
  type                String
  translation         String
  forms               String[] @default([])
  isIrregular         Boolean  @default(false)
  isCountable         Boolean  @default(false)
  sentenceIds         String[] @default([])

  @@unique([expressionId, expressionContextId])
  @@index([phrase])
  @@index([forms])
  @@index([translation])
  @@index([type])
  @@index([isIrregular])
  @@index([isCountable])
}

//----------------------------------

// Box Bounded Context
model Box {
  id                   String   @id @default(uuid())
  title                String
  createdAt            DateTime @default(now())
  expressionContextIds String[] @default([])
}

//----------------------------------

// Answers Bounded Context
model AnswerExpressionContextReadModel {
  id                  String   @id @default(uuid())
  phrase              String
  expressionId        String
  expressionContextId String   @unique
  type                String
  translation         String
  forms               String[] @default([])
  isIrregular         Boolean  @default(false)
  isCountable         Boolean  @default(false)
  sentenceIds         String[] @default([])

  @@unique([expressionId, expressionContextId])
}

model AnswerSentenceReadModel {
  id                  String @id @default(uuid())
  sentenceId          String @unique
  content             String
  translation         String
  expressionContextId String
  expressionId        String
}

//----------------------------------
