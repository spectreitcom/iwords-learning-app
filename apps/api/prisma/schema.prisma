generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Users Bounded Context
//----------------------------------

// Admin Users Bounded Context
//----------------------------------

// Dictionary Bounded Context
model Expression {
  id        String   @id @default(uuid())
  phrase    String   @unique
  createdAt DateTime @default(now())
}

